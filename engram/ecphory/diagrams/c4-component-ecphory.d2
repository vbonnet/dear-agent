legend: {
  near: bottom-right
  style.fill: "#FFFFFF"
  style.stroke: "#333333"

  legend_title: "Component Types" {
    shape: text
    style.bold: true
  }

  tier1_color: "Tier 1: Fast Filter" {
    shape: rectangle
    style.fill: "#85C1E9"
  }

  tier2_color: "Tier 2: Semantic Ranking" {
    shape: rectangle
    style.fill: "#F7DC6F"
  }

  tier3_color: "Tier 3: Budget Management" {
    shape: rectangle
    style.fill: "#BB8FCE"
  }

  boosting_color: "Failure Boosting" {
    shape: rectangle
    style.fill: "#F1948A"
  }

  provider_color: "LLM Providers" {
    shape: rectangle
    style.fill: "#7DCEA0"
  }

  external_color: "External Dependencies" {
    shape: rectangle
    style.fill: "#E8E8E8"
  }
}

# Notes
notes: {
  near: bottom-left
  style.fill: "#FEF9E7"
  style.stroke: "#F39C12"

  notes_title: "Key Architectural Features" {
    shape: text
    style.bold: true
  }

  note1: "• 3-tier pipeline: Filter → Rank → Budget" {
    shape: text
  }

  note2: "• Multi-provider support with auto-detection" {
    shape: text
  }

  note3: "• Failure-aware boosting for debugging queries" {
    shape: text
  }

  note4: "• Rate limiting: 100/hour, 20/session" {
    shape: text
  }

  note5: "• Thread-safe concurrent query execution" {
    shape: text
  }

  note6: "• Async telemetry & metadata updates" {
    shape: text
  }
}

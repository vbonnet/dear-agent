# Test: Session creation with Manifest v2 and JSONL format
# Validates: Core session creation (FR1.1), Manifest format (FR2.3), JSONL format (FR2.2)
#
# This test ensures that:
# - csm new command creates a session successfully
# - Manifest v2 format is used (schema_version: "2.0")
# - Session ID is a proper UUID (not "session-<name>")
# - JSONL file is created (not XML)
# - JSONL contains valid JSON session_start event

[!can-create-tmux-session] skip 'cannot create tmux sessions in this environment'

# Create a new session
# Use --agent gpt to avoid 60s ready-file wait (E2E tests use dummy API key)
exec agm session new bdd-create-test --agent gpt --detached
stdout 'Session.*created'

# Verify AGM created the manifest (AGM's responsibility)
exists $HOME/sessions/bdd-create-test/manifest.yaml

# Verify Manifest v2 schema (AGM's responsibility)
exec cat $HOME/sessions/bdd-create-test/manifest.yaml
stdout 'schema_version: "2.0"'

# Verify session_id is a proper UUID (not "session-<name>" pattern from old bug)
stdout 'session_id: [0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'
! stdout 'session_id: session-bdd-create-test'
! stdout 'session_id: session-'

# Verify name field is set correctly
stdout 'name: bdd-create-test'

# Note: session.jsonl is created by Claude CLI's SessionStart hook during initialization
# Since tests use dummy API key, Claude can't complete initialization
# We verify AGM's responsibilities (manifest creation with v3 schema) work correctly

# Cleanup
exec agm session archive bdd-create-test --force

# Test: Claude adapter behavioral validation
# Validates: Claude adapter integration (FR2.1)
#
# This test ensures that:
# - Claude adapter initializes correctly during session creation
# - No errors occur during adapter operations
# - Adapter supports basic session lifecycle (create, resume, list, archive)
# - Phase 0 refactoring to Agent interface doesn't break behavior

[!can-create-tmux-session] skip 'cannot create tmux sessions in this environment'

# Create session - should initialize Claude adapter
# Use --agent gpt to avoid 60s ready-file wait (E2E tests use dummy API key)
exec agm session new bdd-adapter-test --agent gpt --detached --sessions-dir $HOME/sessions
stdout 'Session.*created'

# Verify no adapter-related errors occurred
! stderr 'error|Error|ERROR'
! stderr 'failed|Failed|FAILED'
! stderr 'adapter.*error'
! stderr 'agent.*error'

# Verify session is functional (basic adapter operations work)
exec agm session list --sessions-dir $HOME/sessions
stdout 'bdd-adapter-test'

# Test adapter re-initialization on resume (if tmux available)
# Note: csm resume doesn't support --detached flag, so we skip interactive attach test
# [exec:tmux] exec agm session resume bdd-adapter-test
# [exec:tmux] ! stderr 'error|Error|ERROR'

# Verify session manifest is intact (AGM's adapter persists state correctly)
exists $HOME/sessions/bdd-adapter-test/manifest.yaml

# Verify manifest is valid (adapter didn't corrupt metadata)
exec cat $HOME/sessions/bdd-adapter-test/manifest.yaml
stdout 'schema_version: "2.0"'
stdout 'session_id: [0-9a-f]{8}-'

# Note: session.jsonl is created by Claude CLI's SessionStart hook
# Tests use dummy API key so full Claude initialization doesn't complete

# Archive should work with adapter (cleanup operations)
exec agm session archive bdd-adapter-test --sessions-dir $HOME/sessions --force
! stderr 'error|Error|ERROR'

# Verify archive succeeded (adapter cleanup worked)
exec agm session list --sessions-dir $HOME/sessions
! stdout 'bdd-adapter-test'
